ADMIN_INITIAL_PASSWORD=change-me
NODE_ENV=production
AUTH_TRUST_HOST=true
SYNWEB_GATEWAY_WEBHOOK=https://n8n.worqshop.io/webhook/synweb/inbound
SYNWEB_CALLBACK_SECRET_HEADER=X-Syn-Callback-Secret
SYNWEB_READSTATE_WEBHOOK=https://n8n.worqshop.io/webhook/synweb/readstate
SYNWEB_INGEST_WEBHOOK=https://n8n.worqshop.io/webhook/synweb/ingest-file
PUBLIC_BASE_URL=https://syn.worqshop.io
GOOGLE_AI_API_KEY=your-google-ai-api-key-here
