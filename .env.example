# Copy to .env and fill in real values. .env is gitignored.
POSTGRES_PASSWORD=change-me
POSTGRES_DB=synweb
POSTGRES_USER=synweb
DATABASE_URL=postgresql://synweb:change-me@postgres:5432/synweb
REDIS_URL=redis://redis:6379/0
NEXTAUTH_SECRET=change-me-long-random
NEXTAUTH_URL=https://syn.worqshop.io
N8N_WEBHOOK_BASE=https://n8n.worqshop.io/webhook
N8N_CALLBACK_SECRET=change-me-shared-with-n8n
