      {
        "parameters": {
          "jsCode": "const items = $input.all();\nconst item = items[0].json;\n\nconst messageText = item.event?.text || item.text || '';\n\nconst BOTS = {\n  'U0AKTCAEUH1': { name: 'Syn', target: 'coordinator', slot: 0 },\n  'U0AL64H4GES': { name: 'Alpha', target: 'audience', slot: 1 },\n  'U0AM2ESA872': { name: 'Beta', target: 'audience', slot: 2 },\n  'U0AL87H2NQJ': { name: 'Gamma', target: 'audience', slot: 3 },\n  'U0AL886C5R8': { name: 'Sigma', target: 'audience', slot: 4 },\n  'U0AL1SN0EP5': { name: 'Omega', target: 'audience', slot: 5 }\n};\n\nlet detectedBot = null;\nfor (const [botId, botInfo] of Object.entries(BOTS)) {\n  if (messageText.includes(`<@${botId}>`)) {\n    detectedBot = { ...botInfo, botId };\n    break;\n  }\n}\n\nif (!detectedBot) return [];\n\nconst threadTs = item.event?.thread_ts || item.event?.ts || item.thread_ts || item.ts;\nconst channelId = item.event?.channel || item.channel;\nconst userId = item.event?.user || item.user;\nconst cleanMessage = messageText.replace(/<@[A-Z0-9]+>/g, '').trim();\n\nconst files = item.event?.files || item.files || [];\nconst hasFiles = files.length > 0;\n\nconst MAX_FILE_SIZE = 10 * 1024 * 1024;\nconst ALLOWED = ['application/pdf', 'image/png', 'image/jpeg', 'image/gif', 'image/webp'];\n\nconst baseData = {\n  sessionId: threadTs,\n  channelId,\n  userId,\n  cleanMessage,\n  targetWorkflow: detectedBot.target,\n  slotNumber: detectedBot.slot,\n  botName: detectedBot.name\n};\n\n// No files: single item\nif (!hasFiles) {\n  return [{ json: { ...baseData, hasFiles: false, fileStatus: 'no_files', fileInfo: null, fileUrl: '' } }];\n}\n\n// Multi-file: one item per valid file\nconst results = [];\nfor (let i = 0; i < files.length; i++) {\n  const f = files[i];\n  const mime = f.mimetype || '';\n  const size = f.size || 0;\n  const name = f.name || 'unknown';\n  const url = f.url_private || f.url_private_download || '';\n\n  if (!ALLOWED.includes(mime)) {\n    results.push({ json: { ...baseData, hasFiles: true, fileStatus: 'rejected', rejectionReason: `Dateityp ${mime} nicht unterstuetzt.`, fileInfo: { fileName: name, mimeType: mime, fileSize: size }, fileUrl: url, fileIndex: i, totalFiles: files.length } });\n  } else if (size > MAX_FILE_SIZE) {\n    results.push({ json: { ...baseData, hasFiles: true, fileStatus: 'rejected', rejectionReason: `${name} ist ${(size/1024/1024).toFixed(1)} MB. Max 10 MB.`, fileInfo: { fileName: name, mimeType: mime, fileSize: size }, fileUrl: url, fileIndex: i, totalFiles: files.length } });\n  } else {\n    results.push({ json: { ...baseData, hasFiles: true, fileStatus: mime === 'application/pdf' ? 'pdf' : 'image', fileInfo: { fileName: name, mimeType: mime, fileSize: size }, fileUrl: url, fileIndex: i, totalFiles: files.length } });\n  }\n}\n\nreturn results;"
        },
