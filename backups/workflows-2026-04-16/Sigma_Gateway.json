      {
        "parameters": {
          "jsCode": "// Prep each file for saving\n// Anthropic output: $json.content[0].text (non-simplified) or $json.message (simplified)\nconst items = $input.all();\nconst detectItems = $('Detect Bot').all().filter(i => i.json.hasFiles && i.json.fileStatus !== 'rejected');\nconst results = [];\n\nfor (let i = 0; i < items.length; i++) {\n  const json = items[i].json;\n\n  // Extract text from Anthropic output formats\n  let llmOutput = '';\n  if (typeof json.message === 'string') {\n    llmOutput = json.message;\n  } else if (json.text) {\n    llmOutput = json.text;\n  } else if (Array.isArray(json.content)) {\n    llmOutput = json.content.filter(c => c.type === 'text').map(c => c.text).join('\\n');\n  } else if (json.content?.parts) {\n    llmOutput = json.content.parts.filter(p => p.text).map(p => p.text).join('\\n');\n  } else if (json.output) {\n    llmOutput = json.output;\n  }\n\n  const d = detectItems[i]?.json || detectItems[0]?.json || {};\n\n  results.push({\n    json: {\n      sessionId: d.sessionId,\n      channelId: d.channelId,\n      userId: d.userId,\n      cleanMessage: d.cleanMessage,\n      targetWorkflow: d.targetWorkflow,\n      slotNumber: d.slotNumber,\n      botName: d.botName,\n      fileInfo: d.fileInfo,\n      fileUrl: d.fileUrl || '',\n      fileStatus: 'accepted',\n      extractedText: llmOutput,\n      charCount: llmOutput.length,\n      summary: llmOutput.substring(0, 500) || 'File: ' + (d.fileInfo?.fileName || 'unknown')\n    }\n  });\n}\n\nreturn results;"
        },
