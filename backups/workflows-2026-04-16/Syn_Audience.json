      {
        "parameters": {
          "jsCode": "// Re-attach binaries from Merge Files + combine with Load Memory results\nconst mergeItem = $('Merge Files').first();\nconst memoryItems = $('Load Memory').all();\n\n// Build conversation history\nlet conversationHistory = 'Kein bisheriges Gespraech';\nif (memoryItems.length > 0 && memoryItems[0].json && Object.keys(memoryItems[0].json).length > 0) {\n  const history = memoryItems.reverse().map(i => {\n    const j = i.json;\n    const role = j.role || j.type || 'unknown';\n    const content = j.content || j.message || j.text || JSON.stringify(j);\n    return role + ': ' + content;\n  }).join('\\n');\n  if (history.trim()) conversationHistory = history;\n}\n\nreturn [{\n  json: {\n    ...mergeItem.json,\n    conversationHistory\n  },\n  binary: mergeItem.binary || undefined\n}];"
        },
