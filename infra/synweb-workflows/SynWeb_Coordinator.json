        "parameters": {
          "jsCode": "const items = $input.all();\nconst phaseData = $('Phase Detection').first().json;\n\n// If DataTable returned 0 rows (no session exists yet), create a placeholder\n// so the Route switch can evaluate the 'id notExists' condition\nif (items.length === 0 || !items[0].json || Object.keys(items[0].json).length === 0) {\n  return [{\n    json: {\n      _noSessionFound: true,\n      ...phaseData\n    }\n  }];\n}\n\n// Session found - pass through with phase data merged\nreturn [{\n  json: {\n    ...items[0].json,\n    ...phaseData\n  }\n}];"
        },
