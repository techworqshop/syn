          "sendBody": true,
          "specifyBody": "json",
          "jsonBody": "={{ JSON.stringify({sessionId: $('Execute Workflow Trigger').item.json.session_id, kind: 'synthesis', roundNumber: $('Execute Workflow Trigger').item.json.round_number, text: ($('Synthesize With Files').isExecuted ? $('Synthesize With Files').first().json.content[0].text : $('Synthesize No Files').first().json.content[0].text)}) }}",
          "options": {
            "timeout": 15000
          }
        },
        "continueOnFail": true
      }
