    "nodes": [
      {
        "id": "03cbc922-9b34-42a0-b57c-86fa55aac152",
        "name": "Execute Workflow Trigger",
        "type": "n8n-nodes-base.executeWorkflowTrigger",
        "typeVersion": 1.1,
        "position": [
          -100,
          300
        ],
        "parameters": {
          "workflowInputs": {
            "values": [
              {
                "name": "session_id"
              },
              {
                "name": "round_number",
                "type": "number"
              },
              {
                "name": "problem_brief"
              }
            ]
          }
        }
      },
      {
        "id": "5dc4c119-863d-442f-85d7-d1296cb01785",
        "name": "Get Persona Responses",
        "type": "n8n-nodes-base.dataTable",
        "typeVersion": 1.1,
        "position": [
          150,
          200
        ],
        "parameters": {
          "operation": "get",
          "dataTableId": {
            "__rl": true,
            "mode": "name",
            "value": "panel_personas"
          },
          "matchType": "allConditions",
          "filters": {
            "conditions": [
              {
                "keyName": "session_id",
                "keyValue": "={{ $json.session_id }}"
              }
            ]
          },
          "returnAll": true
        }
      },
      {
        "id": "8a6d1c3f-3777-4996-a22b-a465db3cf2ee",
        "name": "Get Session Files",
        "type": "n8n-nodes-base.dataTable",
        "typeVersion": 1.1,
        "position": [
          150,
          400
        ],
        "parameters": {
          "operation": "get",
          "dataTableId": {
            "__rl": true,
            "mode": "name",
            "value": "panel_files"
          },
          "matchType": "allConditions",
          "filters": {
            "conditions": [
              {
                "keyName": "session_id",
                "keyValue": "={{ $('Execute Workflow Trigger').item.json.session_id }}"
              }
            ]
          },
          "returnAll": true,
          "alwaysOutputData": true
        },
        "executeOnce": true
      },
      {
        "id": "46f21ed2-54b6-4c43-bedb-bf54b63a491c",
        "name": "Aggregate",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          400,
          200
        ],
        "parameters": {
          "jsCode": "const trigger = $('Execute Workflow Trigger').first().json;\nconst roundNumber = trigger.round_number;\nconst responseField = `round_${roundNumber}_response`;\nconst personas = $input.all().map(i => i.json);\nconst allResponses = personas.map(p => {\n  return `--- ${p.name} (${p.type || ''}) ---\\nPerspective: ${p.core_perspective || ''}\\n\\n${p[responseField] || 'No response yet'}`;\n}).join('\\n\\n');\nreturn [{json: {session_id: trigger.session_id, round_number: roundNumber, problem_brief: trigger.problem_brief, all_responses: allResponses, persona_count: personas.length}}];"
        }
      },
      {
        "id": "9c75306e-c962-4ec5-9356-6ecc90ad70f0",
        "name": "Has Files?",
        "type": "n8n-nodes-base.if",
        "typeVersion": 2.3,
        "position": [
          650,
          400
        ],
        "parameters": {
          "conditions": {
            "options": {
              "caseSensitive": true,
              "typeValidation": "strict",
              "version": 2,
              "leftValue": ""
            },
            "conditions": [
              {
                "leftValue": "={{ $json.file_url }}",
                "rightValue": "",
                "operator": {
                  "type": "string",
                  "operation": "exists",
                  "singleValue": true
                }
              }
            ],
            "combinator": "and"
          }
        }
      },
      {
        "id": "b14eb5fb-2b3b-4b3a-a3dd-4da85e8c4947",
        "name": "Download File",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.2,
        "position": [
          900,
          400
        ],
        "parameters": {
          "url": "={{ $json.file_url }}",
          "options": {}
        }
      },
      {
        "id": "5e1d12ed-7520-434c-b653-c566a32b841a",
        "name": "Merge Files",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          1150,
          400
        ],
        "parameters": {
          "jsCode": "const aggregate = $('Aggregate').first().json;\nconst items = $input.all();\nconst mergedBinary = {};\nconst keys = [];\nlet count = 0;\nfor (const it of items) {\n  if (it.binary) {\n    for (const [k, v] of Object.entries(it.binary)) {\n      const nk = `file_${count}`;\n      mergedBinary[nk] = v; keys.push(nk); count++;\n    }\n  }\n}\nreturn [{json: {...aggregate, binaryKeys: keys.join(',')}, binary: count > 0 ? mergedBinary : undefined}];"
        }
      },
      {
        "id": "4d92beb2-55c8-4d19-aa3c-ba3d275bdf4a",
        "name": "Synthesize With Files",
        "type": "@n8n/n8n-nodes-langchain.anthropic",
        "typeVersion": 1,
        "position": [
          1400,
          400
        ],
        "parameters": {
          "modelId": {
            "__rl": true,
            "mode": "id",
            "value": "claude-sonnet-4-5-20250929"
          },
          "messages": {
            "values": [
              {
                "content": "=RUNDE {{ $json.round_number }} - SYNTHESE\n\nPROBLEM BRIEF:\n{{ $json.problem_brief }}\n\nALLE PERSONA-ANTWORTEN ({{ $json.persona_count }} Panelisten):\n{{ $json.all_responses }}\n\nAngehaengte Dateien sind Teil des Panel-Kontexts. Analysiere sie gruendlich und beziehe sie in die Synthese ein.\n\nSektionen:\n1. KONSENS\n2. SPANNUNGSLINIEN\n3. UEBERRASCHUNGEN\n4. OFFENE LUECKEN\n5. ENTSTEHENDE FRAGEN\n\nKeine vorgetaeuschten Konsense. Weise Ideen namentlich zu."
              }
            ]
          },
          "addAttachments": true,
          "attachmentsInputType": "binary",
          "binaryPropertyName": "={{ $json.binaryKeys || 'data' }}",
          "options": {
            "temperature": 0.5,
            "maxTokens": 4096,
            "systemMessage": "Du bist die Syn-Synthese-Engine. Erstelle ehrliche, strukturierte Synthese-Berichte aus mehreren Expertenperspektiven. Blaettere NIEMALS Meinungsverschiedenheiten weg. Weise Ideen namentlich zu. ANTWORTE IMMER in der gleichen Sprache wie die Persona-Antworten (Deutsch, wenn die Personas Deutsch sprechen). FORMATIERUNG: nur Plain Text, kein Markdown."
          }
        },
        "credentials": {
          "anthropicApi": {
            "id": "xryPDagnAi6vifng",
            "name": "Anthropic account"
          }
        }
      },
