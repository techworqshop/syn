# Syn cleanup cron jobs. Install:
#   cp /root/synweb/infra/synweb-cleanup.cron /etc/cron.d/synweb-cleanup
SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

30 3 * * * root /root/synweb/infra/cron-scripts/uploads_cleanup.sh
30 5 * * 0 root /root/synweb/infra/cron-scripts/postgres_vacuum.sh
0 2 1 * * root /root/synweb/infra/cron-scripts/log_prune.sh
30 2 1 * * root /root/synweb/infra/cron-scripts/reports_cleanup.sh
0 4 * * 0 root /root/synweb/infra/cron-scripts/orphan_cleanup.sh
0 6 * * 0 root /usr/bin/docker builder prune -af > /var/log/synweb_docker_prune.log 2>&1
